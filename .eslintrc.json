{
  "env": {
    "browser": true,
    "es2021": true,
    "cypress/globals": true
  },
  "extends": ["eslint:recommended", "plugin:cypress/recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "quotes": ["error", "single", {"avoidEscape": true}],
    "semi": ["error", "always"],
    "no-console": "off",
    "prefer-const": "warn"
  }
}
